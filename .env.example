# ===========================================
# AI CS2 Analytics — Environment Variables
# Copy to .env and fill in values
# ===========================================

# Backend
DATABASE_URL=postgresql+asyncpg://cs2user:localdev123@localhost:5432/cs2analytics
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
CLICKHOUSE_URL=http://localhost:8123
ENVIRONMENT=dev

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Auth (JWT)
JWT_SECRET=change-me-in-production-use-64-chars-minimum-random-string-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# MinIO (S3 local)
MINIO_ENDPOINT=http://localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cs2-demos

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=price_solo_placeholder
STRIPE_PRICE_TEAM=price_team_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
FRONTEND_URL=http://localhost:3000

# FACEIT (pro demo ingestion)
FACEIT_API_KEY=
FACEIT_HUB_IDS=

# Rate limiting
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_DEFAULT=60/minute

# File upload
MAX_DEMO_SIZE_MB=200

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
